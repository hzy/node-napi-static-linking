diff --git a/tools/link_napi_addons.py b/tools/link_napi_addons.py
new file mode 100755
index 00000000..a5afbb9d
--- /dev/null
+++ b/tools/link_napi_addons.py
@@ -0,0 +1,175 @@
+#!/usr/bin/env python3
+"""Generate linked-binding wrapper for statically-linked NAPI addons.
+
+For each addon specified as name:path, this script:
+  1. Copies the .a/.lib to a staging directory
+  2. Runs objcopy/llvm-objcopy --redefine-sym to give each addon unique symbols
+  3. Generates a C++ file that registers them as Node.js linked bindings
+
+Called by configure.py when --link-napi-addon is used.
+
+On Windows, llvm-objcopy from the Visual Studio LLVM toolchain is used.
+On Linux/macOS, GNU objcopy (or llvm-objcopy if available) is used.
+"""
+
+import argparse
+import os
+import platform
+import shutil
+import subprocess
+import sys
+
+
+def _find_objcopy():
+    """Find an objcopy binary that supports --redefine-sym."""
+    is_win = platform.system() == "Windows"
+
+    if is_win:
+        # Node.js v24+ requires ClangCL, so LLVM is always installed.
+        # llvm-objcopy is in the same directory as clang-cl.exe.
+        # Check VCINSTALLDIR first (set by vcvarsall.bat / vcbuild.bat).
+        vcinstalldir = os.environ.get("VCINSTALLDIR", "")
+        if vcinstalldir:
+            candidate = os.path.join(vcinstalldir, "Tools", "Llvm", "x64", "bin", "llvm-objcopy.exe")
+            if os.path.isfile(candidate):
+                return candidate
+
+        # Fallback: try PATH
+        for name in ("llvm-objcopy", "llvm-objcopy.exe"):
+            path = shutil.which(name)
+            if path:
+                return path
+
+        print(
+            "ERROR: llvm-objcopy not found. Install Visual Studio with the C++ Clang tools, or add llvm-objcopy to PATH.",
+            file=sys.stderr,
+        )
+        sys.exit(1)
+    else:
+        # Linux / macOS: prefer objcopy, fall back to llvm-objcopy
+        for name in ("objcopy", "llvm-objcopy"):
+            path = shutil.which(name)
+            if path:
+                return path
+
+        print(
+            "ERROR: neither objcopy nor llvm-objcopy found. Install binutils or llvm.",
+            file=sys.stderr,
+        )
+        sys.exit(1)
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--output-dir", required=True)
+    parser.add_argument("addons", nargs="+", help="name:/path/to/lib.a or name:/path/to/lib.lib")
+    args = parser.parse_args()
+
+    output_dir = os.path.abspath(args.output_dir)
+    os.makedirs(output_dir, exist_ok=True)
+
+    is_win = platform.system() == "Windows"
+    objcopy = _find_objcopy()
+    print(f"Using objcopy: {objcopy}", file=sys.stderr)
+
+    addons = []
+    for spec in args.addons:
+        # Format: name:/path/to/lib.a  or  name:C:\path\to\lib.lib
+        # split(":", 1) gives ["name", "/path/..."] or ["name", "C:\path\..."].
+        # On Windows the path part may start with a drive letter like "C:\",
+        # which itself contains ":". Handle this: if the path part is a single
+        # letter followed by ":\", rejoin with the next split.
+        parts = spec.split(":", 1)
+        if len(parts) != 2 or not parts[0]:
+            print(f"ERROR: expected name:/path, got: {spec}", file=sys.stderr)
+            sys.exit(1)
+        name, path = parts
+        # Check if we accidentally split a Windows drive letter:
+        # name="simple_napi", path="C" won't happen since split(":", 1) yields
+        # the full remainder. But if name itself looks like a single drive
+        # letter (e.g. spec="C:\foo"), that means no name was provided.
+        # In practice addon names must be valid C identifiers (len > 1), so
+        # a single-char name that equals a drive letter is rejected.
+        if len(name) == 1 and name.isalpha() and path.startswith(("\\", "/")):
+            print(f"ERROR: addon name cannot be a single letter (conflicts with drive letters): {spec}", file=sys.stderr)
+            sys.exit(1)
+        path = os.path.abspath(path)
+        if not os.path.isfile(path):
+            print(f"ERROR: file not found: {path}", file=sys.stderr)
+            sys.exit(1)
+        addons.append((name, path))
+
+    lib_paths = []
+    for name, src in addons:
+        ext = ".lib" if is_win else ".a"
+        dst = os.path.join(output_dir, f"lib_napi_{name}{ext}")
+        shutil.copy2(src, dst)
+        subprocess.check_call(
+            [
+                objcopy,
+                "--redefine-sym",
+                f"napi_register_module_v1=napi_register_module_v1__{name}",
+                "--redefine-sym",
+                f"node_api_module_get_api_version_v1=node_api_module_get_api_version_v1__{name}",
+                dst,
+            ]
+        )
+        lib_paths.append(dst)
+
+    wrapper = os.path.join(output_dir, "linked_napi_addons.cc")
+    _generate(wrapper, addons)
+
+    # Machine-readable output consumed by configure.py
+    print(f"WRAPPER:{wrapper}")
+    for p in lib_paths:
+        print(f"LIB:{p}")
+
+
+def _generate(path, addons):
+    """Emit the C++ wrapper that registers every addon."""
+    w = []
+    w.append("// AUTO-GENERATED by tools/link_napi_addons.py — do not edit.")
+    w.append('#include "node_binding.h"')
+    w.append("")
+
+    for name, _ in addons:
+        w.append(f'extern "C" napi_value napi_register_module_v1__{name}(')
+        w.append(f"    napi_env env, napi_value exports);")
+    w.append("")
+
+    for name, _ in addons:
+        w.append(f"static void LinkedNapiInit_{name}(")
+        w.append(f"    v8::Local<v8::Object> exports,")
+        w.append(f"    v8::Local<v8::Value> module,")
+        w.append(f"    v8::Local<v8::Context> context,")
+        w.append(f"    void*) {{")
+        w.append(f"  napi_module_register_by_symbol(")
+        w.append(f"      exports, module, context,")
+        w.append(f"      napi_register_module_v1__{name},")
+        w.append(f"      NODE_API_DEFAULT_MODULE_API_VERSION);")
+        w.append(f"}}")
+        w.append("")
+
+    for name, _ in addons:
+        w.append(f"static node::node_module linked_napi_module_{name} = {{")
+        w.append(f"    NODE_MODULE_VERSION,")
+        w.append(f"    node::ModuleFlags::kLinked,")
+        w.append(f"    nullptr, __FILE__, nullptr,")
+        w.append(f"    LinkedNapiInit_{name},")
+        w.append(f'    "{name}",')
+        w.append(f"    nullptr, nullptr,")
+        w.append(f"}};")
+        w.append("")
+
+    w.append("NODE_C_CTOR(register_linked_napi_addons) {")
+    for name, _ in addons:
+        w.append(f"  node_module_register(&linked_napi_module_{name});")
+    w.append("}")
+    w.append("")
+
+    with open(path, "w") as f:
+        f.write("\n".join(w))
+
+
+if __name__ == "__main__":
+    main()
-- 
2.39.5

