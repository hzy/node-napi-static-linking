From 387375df6abff64294d1ef486fe2dde21ccc08c4 Mon Sep 17 00:00:00 2001
From: Zhiyuan Hong <hongzhiyuan.hzy@bytedance.com>
Date: Thu, 16 Apr 2026 14:58:02 +0800
Subject: [PATCH] feat: add --link-napi-addon configure flag

Add support for statically linking NAPI addons into the Node.js binary
as linked bindings, accessible via process._linkedBinding('name').

Usage:
  ./configure --link-napi-addon name:/path/to/libaddon.a

The configure step automatically:
  1. Copies each .a to a staging directory (out/linked_napi_addons/)
  2. Uses objcopy --redefine-sym to give each addon unique symbols
     (resolves napi_register_module_v1 collisions across multiple addons)
  3. Generates a C++ wrapper that registers all addons via NODE_C_CTOR

Changes:
  - configure.py: new --link-napi-addon flag + processing logic
  - node.gyp: new variables linked_napi_addon_sources/libs
  - tools/link_napi_addons.py: new script (objcopy + codegen)
---
 configure.py              |  29 ++++++++++
 node.gyp                  |   7 +++
 tools/link_napi_addons.py | 112 ++++++++++++++++++++++++++++++++++++++
 3 files changed, 148 insertions(+)
 create mode 100755 tools/link_napi_addons.py

diff --git a/configure.py b/configure.py
index f7fababe..fa0cd319 100755
--- a/configure.py
+++ b/configure.py
@@ -226,6 +226,15 @@ parser.add_argument("--link-module",
          "e.g. /root/x/y.js will be referenced via require('root/x/y'). "
          "Can be used multiple times")
 
+parser.add_argument("--link-napi-addon",
+    action="append",
+    dest="linked_napi_addons",
+    help="Statically link a NAPI addon into the binary as a linked binding. "
+         "Format: name:/path/to/libaddon.a  "
+         "The addon becomes available via process._linkedBinding('name'). "
+         "The .a must export the standard napi_register_module_v1 symbol. "
+         "Can be used multiple times for multiple addons.")
+
 parser.add_argument("--openssl-conf-name",
     action="store",
     dest="openssl_conf_name",
@@ -1895,6 +1904,26 @@ def configure_node(o):
   if options.linked_module:
     o['variables']['linked_module_files'] = options.linked_module
 
+  o["variables"]["linked_napi_addon_sources"] = []
+  o["variables"]["linked_napi_addon_libs"] = []
+  if options.linked_napi_addons:
+    staging = os.path.join(os.getcwd(), "out", "linked_napi_addons")
+    tool = os.path.join(os.getcwd(), "tools", "link_napi_addons.py")
+    cmd = [sys.executable, tool, "--output-dir", staging] + options.linked_napi_addons
+    print_verbose(" ".join(cmd))
+    proc = subprocess.run(cmd, capture_output=True, text=True)
+    if proc.returncode != 0:
+      error("link_napi_addons.py failed:\n" + proc.stderr)
+    for line in proc.stdout.splitlines():
+      if line.startswith("WRAPPER:"):
+        abspath = line[len("WRAPPER:"):]
+        o["variables"]["linked_napi_addon_sources"].append(
+            os.path.relpath(abspath, os.getcwd()))
+      elif line.startswith("LIB:"):
+        o["variables"]["linked_napi_addon_libs"].append(line[len("LIB:"):])
+    names = [s.split(":")[0] for s in options.linked_napi_addons]
+    print("Linked NAPI addons: " + ", ".join(names))
+
   o['variables']['asan'] = int(options.enable_asan or 0)
   o['variables']['ubsan'] = int(options.enable_ubsan or 0)
 
